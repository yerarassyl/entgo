{
  "name": "entgo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:mobile": "next dev -H 0.0.0.0",
    "build": "next build",
    "vercel-build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "pretest:e2e": "tsx --env-file=.env scripts/reset-e2e-state.ts",
    "test:load": "node scripts/load-smoke.mjs",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "infra:postgres": "pglite-server --db=./.data/postgres --port=5432 --max-connections=50",
    "infra:redis": "node scripts/start-redis.mjs",
    "infra:start": "concurrently --kill-others --names postgres,redis \"npm:infra:postgres\" \"npm:infra:redis\"",
    "db:start": "npm run infra:postgres",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:deploy": "prisma migrate deploy",
    "admin:promote": "tsx --env-file=.env scripts/promote-admin.ts",
    "admin:local": "tsx --env-file=.env scripts/create-local-admin.ts",
    "admin:content-local": "tsx --env-file=.env scripts/create-local-content-admin.ts",
    "premium:local": "tsx --env-file=.env scripts/create-local-premium-user.ts",
    "questions:import": "tsx --env-file=.env scripts/import-question-bank.ts",
    "mobile:start": "npm --prefix mobile run start",
    "mobile:android": "npm --prefix mobile run android",
    "mobile:ios": "npm --prefix mobile run ios",
    "mobile:web": "npm --prefix mobile run web",
    "mobile:typecheck": "npm --prefix mobile run typecheck"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource/instrument-serif": "^5.2.8",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "html2canvas": "^1.4.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "redis": "^6.0.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite-socket": "^0.2.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "prisma": "^6.19.3",
    "redis-memory-server": "^0.16.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
